<Window x:Class="MVVMMini.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MVVMMini"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
  <Window.DataContext>
    <local:MainViewModel/>
  </Window.DataContext>
  <Grid>
    <TextBox HorizontalAlignment="Left" Margin="133,138,0,0" TextWrapping="Wrap" Text="{Binding Number1}" VerticalAlignment="Top" Width="120"/>
    <TextBox HorizontalAlignment="Left" Margin="371,138,0,0" TextWrapping="Wrap" Text="{Binding Number2}" VerticalAlignment="Top" Width="120"/>
    <TextBlock HorizontalAlignment="Left" Margin="268,184,0,0" TextWrapping="Wrap" Text="{Binding Result}" VerticalAlignment="Top"/>
    <Button Content="+"  HorizontalAlignment="Left" Margin="161,234,0,0" VerticalAlignment="Top" Width="21" Command="{Binding PlusCommand}"/>
    <Button Content="-" HorizontalAlignment="Left" Margin="360,234,0,0" VerticalAlignment="Top" Width="22" Command="{Binding MinusCommand}"/>
    <Slider HorizontalAlignment="Left" Margin="133,107,0,0" VerticalAlignment="Top" Width="120" Maximum="10000" Value="{Binding Number1}"/>
    <Slider HorizontalAlignment="Left" Margin="371,107,0,0" VerticalAlignment="Top" Width="120" Maximum="10000" Value="{Binding Number2}"/>
    <Menu VerticalAlignment="Top">
      <MenuItem Header="Calculation">
        <MenuItem Header="+" ToolTip="Addition" Command="{Binding PlusCommand}"/>
        <MenuItem Header="-" ToolTip="Subtraction" Command="{Binding MinusCommand}"/>
      </MenuItem>
    </Menu>

  </Grid>
</Window>
