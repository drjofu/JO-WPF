<Window x:Class="WpfApp1.DockPanelSample"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="DockPanelSample" Height="450" Width="800">
  <DockPanel LastChildFill="True">
    <Button Content="Alfa" DockPanel.Dock="Top"/>
    <StatusBar DockPanel.Dock="Bottom" Height="30"></StatusBar>
    <Button Content="Bravo" DockPanel.Dock="Bottom"/>
    <Button Content="Charly" DockPanel.Dock="Right"/>
    <Button Content="Delta"/>
    <Button Content="Echo" DockPanel.Dock="Top"/>
    <Button Content="Foxtrot"/>
    <Button Content="Golf"/>
    <Button Content="Hotel"/>
  </DockPanel>
</Window>
