<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        FontSize="30"
        Title="1. Test" Height="450" Width="800">
  <Canvas>
    <Button Canvas.Left="10" Canvas.Top="10" Content="Hello world!" FontSize="20" Click="Button_Click"/>
    <Button  Canvas.Left="10" Canvas.Top="50" Click="ButtonClick">
      <Button.RenderTransform>
        <TransformGroup>
          <TranslateTransform  X="200"/>
          <ScaleTransform ScaleX="2" ScaleY="3"/>
          <RotateTransform Angle="30"/>
        </TransformGroup>
      </Button.RenderTransform>
      <StackPanel Orientation="Horizontal">
        <Ellipse Width="50" Height="50"  Margin="5 10 20 40">
          <Ellipse.Fill>
            <ImageBrush ImageSource="/Koala.jpg" Stretch="Uniform"/>
          </Ellipse.Fill>
        </Ellipse>
        <TextBlock Text="Please press..." Margin="10" VerticalAlignment="Center" />
        <Ellipse Width="50" Height="50" Fill="Green"/>
        <Ellipse Width="50" Height="50" Fill="Orange"/>
        <Ellipse Height="0" Stroke="Black" Width="100"/>
      </StackPanel>
    </Button>
    <TextBlock Text="Hello world, this is WPF" TextWrapping="Wrap" Width="100" Height="400" Canvas.Left="205" Canvas.Top="25"/>
    <Image Canvas.Top="400" Canvas.Left="10" Source="/Koala.jpg" Stretch="None" Width="400"  Height="400"/>
  </Canvas>
</Window>
