<Window x:Class="WpfApp1.TextBlockSample"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="TextBlockSample" Height="450" Width="800">
    <Grid>
    <TextBlock>
      <Bold>bold text</Bold> or <Italic>italic text</Italic> or <Underline>underlined text</Underline>
      <Span Foreground="Red">red text</Span>
      <Hyperlink Click="ShowMessage" NavigateUri="asdfasdf">Press me</Hyperlink>
      
    </TextBlock>
  </Grid>
</Window>
