<Window x:Class="WpfApp1.GridSample1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GridSample1" Height="450" Width="800">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition />
      <ColumnDefinition Width="2*"/>
      <ColumnDefinition Width="4*"/>
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="40"/>
      <RowDefinition Height="40"/>
      <RowDefinition />
      <RowDefinition />
    </Grid.RowDefinitions>
    <Button Content="A"/>
    <Button Content="B" Grid.Column="1"/>
    <Button Content="C" Grid.Column="2"/>
    <Button Content="D" Grid.Row="1" Grid.Column="2" Grid.RowSpan="2"/>
    <Button Content="E" Grid.Row="2" Grid.ColumnSpan="2"/>
    <Button Content="F" Grid.Row="3"/>
  </Grid>
</Window>
