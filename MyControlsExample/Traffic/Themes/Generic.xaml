<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:Traffic">
  <Style TargetType="{x:Type local:TrafficLight}">
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type local:TrafficLight}">
          <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
            <StackPanel Margin="10">
              <Ellipse Width="50" Height="50" Margin="5" Fill="Red" Name="PART_RedLight"/>
              <Ellipse Width="50" Height="50" Margin="5" Fill="LightGreen" Name="PART_GreenLight"/>
            </StackPanel>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
</ResourceDictionary>
