<Window x:Class="DataBinding1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DataBinding1"
        mc:Ignorable="d" FontSize="25"
        Title="MainWindow" Height="450" Width="800">
  <Window.Resources>
    <local:MyFontSizeConverter x:Key="MFSC" Offset="50" Factor="7"/>
    <local:SmileyConverter x:Key="SC"/>
  </Window.Resources>
  <StackPanel>
    <TextBlock Text="{Binding ElementName=SL, Path=Value, Converter={StaticResource SC}, ConverterParameter=abc}"   FontSize="50"/>
    <Slider Margin="5" Name="SL"/>
    <TextBox Margin="5" Text="{Binding ElementName=SL, Path=Value, StringFormat=0.00}" FontSize="{Binding ElementName=SL, Path=Value, Converter={StaticResource MFSC}}"/>
    <TextBox Margin="5"/>
  </StackPanel>
</Window>
