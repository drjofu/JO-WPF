<Window x:Class="ResourceSample1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ResourceSample1"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
  <Window.Resources>
   
  </Window.Resources>
  <Grid Background="{DynamicResource Brush3}">
    <Ellipse Fill="{DynamicResource Brush1}" HorizontalAlignment="Left" Height="100" Margin="107,84,0,0" Stroke="Black" VerticalAlignment="Top" Width="100">
    </Ellipse>
    <Ellipse HorizontalAlignment="Left" Height="100" Margin="338,84,0,0" Stroke="Black" VerticalAlignment="Top" Width="100" Fill="{DynamicResource Brush1}"/>
    <Ellipse Fill="{DynamicResource Brush2}" HorizontalAlignment="Left" Height="100" Margin="147,254,0,0" Stroke="Black" VerticalAlignment="Top" Width="100">
    </Ellipse>
    <Ellipse HorizontalAlignment="Left" Height="100" Margin="467,226,0,0" Stroke="Black" VerticalAlignment="Top" Width="100" Fill="{DynamicResource Brush3}"/>
    <Ellipse HorizontalAlignment="Left" Height="100" Margin="577,84,0,0" Stroke="Black" VerticalAlignment="Top" Width="100" Fill="{DynamicResource Brush2}"/>
    <Ellipse Fill="{DynamicResource Brush3}" HorizontalAlignment="Left" Height="100" Margin="307,254,0,0" Stroke="Black" VerticalAlignment="Top" Width="100">
    </Ellipse>

  </Grid>
</Window>
